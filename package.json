{
	"name": "blog",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"blog": "bun run cli/blog.ts",
		"blog:prod": "BLOG_API_URL=https://solberg.is bun run cli/blog.ts",
		"atlas": "./scripts/atlas-diff.sh",
		"dev": "vinext dev",
		"build": "vite build",
		"start": "vinext start",
		"deploy": "vite build && wrangler deploy",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"lint": "oxlint -c .oxlintrc.json --type-aware --type-check --deny-warnings",
		"lint:fix": "oxlint -c .oxlintrc.json --type-aware --type-check --fix",
		"format-and-lint": "bun run lint && bun run format:check",
		"format-and-lint:fix": "bun run lint:fix && bun run format",
		"knip": "dotenvx run -- knip",
		"knip:fix": "dotenvx run -- knip --fix",
		"generate:migration": "drizzle-kit generate --config=drizzle-kit.config.ts",
		"run:migration": "wrangler d1 execute solberg-blog --file",
		"studio": "drizzle-kit studio --config=drizzle-kit.config.ts",
		"postinstall": "lefthook install"
	},
	"dependencies": {
		"@headlessui/react": "^2.2.9",
		"@heroicons/react": "^2.2.0",
		"@hono/zod-validator": "^0.7.6",
		"@monaco-editor/react": "^4.7.0",
		"@tanstack/react-pacer": "^0.20.0",
		"arctic": "^3.7.0",
		"better-result": "^2.7.0",
		"clsx": "^2.1.1",
		"culori": "^4.0.2",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.12.8",
		"iron-session": "^8.0.4",
		"monaco-editor": "^0.55.1",
		"react": "^19.2.4",
		"react-aria-components": "^1.16.0",
		"react-dom": "^19.2.4",
		"react-error-boundary": "^6.1.1",
		"recharts": "^3.8.0",
		"remark-gfm": "^4.0.1",
		"remeda": "^2.33.6",
		"rss": "^1.2.2",
		"safe-mdx": "^1.3.9",
		"shiki": "^4.0.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss-react-aria-components": "^2.0.1",
		"tw-animate-css": "^1.4.0",
		"usehooks-ts": "^3.1.1",
		"vinext": "^0.0.29",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.30.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.11",
		"@types/mdx": "^2.0.13",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/rss": "^0.0.32",
		"@vitejs/plugin-rsc": "^0.5.21",
		"drizzle-kit": "^0.31.10",
		"knip": "^5.88.1",
		"lefthook": "^2.1.4",
		"oxfmt": "^0.40.0",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.16.0",
		"postcss": "^8.5.8",
		"react-server-dom-webpack": "^19.2.4",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.1",
		"wrangler": "^4.76.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		]
	},
	"patchedDependencies": {}
}
