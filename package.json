{
	"name": "blog",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"blog": "bun run cli/blog.ts",
		"blog:prod": "BLOG_API_URL=https://www.solberg.is bun run cli/blog.ts",
		"atlas": "./scripts/atlas-diff.sh",
		"dev": "vite dev",
		"build": "vite build && tsc --noEmit",
		"start": "vite preview",
		"deploy": "bun run build && wrangler deploy",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"lint": "oxlint -c .oxlintrc.json --type-aware --type-check --deny-warnings",
		"lint:fix": "oxlint -c .oxlintrc.json --type-aware --type-check --fix",
		"format-and-lint": "bun run lint && bun run format:check",
		"format-and-lint:fix": "bun run lint:fix && bun run format",
		"knip": "dotenvx run -- knip",
		"knip:fix": "dotenvx run -- knip --fix",
		"generate:migration": "drizzle-kit generate --config=drizzle-kit.config.ts",
		"run:migration": "wrangler d1 execute solberg-blog --file",
		"studio": "drizzle-kit studio --config=drizzle-kit.config.ts",
		"postinstall": "lefthook install"
	},
	"dependencies": {
		"@headlessui/react": "^2.2.10",
		"@heroicons/react": "^2.2.0",
		"@hono/zod-validator": "^0.7.6",
		"@monaco-editor/react": "^4.7.0",
		"@tanstack/react-pacer": "^0.22.0",
		"@tanstack/react-router": "^1.170.16",
		"@tanstack/react-start": "^1.168.26",
		"@vitejs/plugin-react": "^6.0.3",
		"arctic": "^3.7.0",
		"better-result": "^2.8.2",
		"clsx": "^2.1.1",
		"culori": "^4.0.2",
		"d3-array": "^3.2.4",
		"d3-interpolate": "^3.0.1",
		"d3-sankey": "^0.12.3",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"drizzle-orm": "^1.0.0-rc.4-5d5b77c",
		"hono": "^4.12.15",
		"iron-session": "^8.0.4",
		"monaco-editor": "^0.55.1",
		"react": "^19.2.5",
		"react-aria-components": "^1.17.0",
		"react-dom": "^19.2.5",
		"react-error-boundary": "^6.1.1",
		"recharts": "^3.8.1",
		"remark-gfm": "^4.0.1",
		"remeda": "^2.34.0",
		"rss": "^1.2.2",
		"safe-mdx": "^1.5.0",
		"shiki": "^4.0.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss-react-aria-components": "^2.1.0",
		"takumi-js": "^2.4.0",
		"tw-animate-css": "^1.4.0",
		"usehooks-ts": "^3.1.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.33.2",
		"@tailwindcss/vite": "^4.2.4",
		"@types/bun": "^1.3.13",
		"@types/d3-array": "^3.2.2",
		"@types/d3-interpolate": "^3.0.4",
		"@types/d3-sankey": "^0.12.5",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"@types/mdx": "^2.0.13",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/rss": "^0.0.32",
		"@vitejs/plugin-rsc": "^0.5.25",
		"drizzle-kit": "^1.0.0-rc.4-5d5b77c",
		"knip": "^6.7.0",
		"lefthook": "^2.1.6",
		"oxfmt": "^0.47.0",
		"oxlint": "^1.62.0",
		"oxlint-tsgolint": "^0.22.1",
		"postcss": "^8.5.12",
		"react-server-dom-webpack": "^19.2.5",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"wrangler": "^4.85.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		]
	},
	"patchedDependencies": {}
}
